<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Teacher Dashboard - Mu Alpha Theta</title>
    <link rel="stylesheet" href="/css/mat.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@300;400;500;600&display=swap"
        rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <script>
        if (localStorage.getItem('theme') === 'dark') {
            document.documentElement.setAttribute('data-theme', 'dark');
        }
    </script>
    <style>
        .meeting-attendees-box {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 1rem;
            margin-top: 1rem;
            padding-top: 1rem;
            border-top: 1px solid #e5e7eb;
        }

        @media (max-width: 768px) {
            .meeting-attendees-box {
                grid-template-columns: 1fr;
            }
        }

        .attended-list,
        .missed-list {
            background: #f8fafc;
            padding: 1rem;
            border-radius: 8px;
            max-height: 250px;
            overflow-y: auto;
            border: 1px solid #e5e7eb;
        }

        .attended-list h5 {
            color: #059669;
            margin-bottom: 0.5rem;
            font-weight: 600;
        }

        .missed-list h5 {
            color: #dc2626;
            margin-bottom: 0.5rem;
            font-weight: 600;
        }

        .student-item {
            padding: 0.25rem 0;
            font-size: 0.85rem;
            border-bottom: 1px solid #f1f5f9;
        }
    </style>
</head>

<body>
    <!-- Navigation Bar -->
    <nav class="navbar" id="navbar">
        <div class="nav-container">
            <div class="nav-logo" style="cursor: pointer;" onclick="window.location.href='/'">
                <img src="/img/logo.png" alt="Mu Alpha Theta Logo" class="nav-logo-img">
                <span class="nav-title">Mu Alpha Theta</span>
            </div>
            <button class="mobile-menu-btn" onclick="document.querySelector('.nav-menu').classList.toggle('active')">
                <i class="fas fa-bars"></i>
            </button>
            <div class="nav-menu">
                <button class="nav-btn" onclick="window.location.href='/resources'">
                    <i class="fas fa-book"></i> Study Resources
                </button>
                <button class="nav-btn" onclick="window.location.href='/ai'">
                    <i class="fas fa-robot"></i> AI Assistance
                </button>
                <button class="nav-btn active">
                    <i class="fas fa-tachometer-alt"></i> Tutoring Dashboard
                </button>
                <button class="nav-btn" onclick="window.location.href='/logout'">
                    <i class="fas fa-sign-out-alt"></i> Logout
                </button>
            </div>
        </div>
    </nav>

    <!-- Main Content -->
    <main class="mat-portal">
        <div class="container" style="max-width: 1400px; padding-top: 2rem;">

            <!-- Dashboard Main Tabs Layout -->
            <div
                style="display: flex; border-bottom: 2px solid #e5e7eb; margin-bottom: 2rem; gap: 1rem; overflow-x: auto;">
                <button class="main-tab-btn active" onclick="switchMainTab('calendar')" id="main-tab-calendar">
                    <i class="fas fa-calendar-alt"></i> Calendar & Sessions
                </button>
                <button class="main-tab-btn" onclick="switchMainTab('tracker')" id="main-tab-tracker">
                    <i class="fas fa-chart-bar"></i> Student Hours Tracker
                </button>
                <button class="main-tab-btn" onclick="switchMainTab('meetings')" id="main-tab-meetings">
                    <i class="fas fa-users"></i> Meetings Management
                </button>
                <button class="main-tab-btn" onclick="switchMainTab('leaderboard')" id="main-tab-leaderboard">
                    <i class="fas fa-trophy"></i> Leaderboard
                </button>
            </div>

            <!-- TAB 1: CALENDAR -->
            <div id="main-content-calendar" class="main-tab-content">
                <div class="modern-calendar-container">
                    <div class="calendar-header-section">
                        <div class="calendar-title-area" style="margin-left: 0;">
                            <div class="title-content">
                                <h1 class="main-title">Tutoring Calendar Management</h1>
                                <p class="subtitle">Manage tutoring sessions and schedules</p>
                            </div>
                        </div>
                        <div class="user-greeting">
                            <span class="greeting-text">Hello, <%= user.firstName %>!</span>
                            <div class="user-avatar">
                                <%= user.firstName.charAt(0).toUpperCase() %>
                            </div>
                        </div>
                    </div>

                    <div class="calendar-actions" style="margin-bottom: 1.5rem;">
                        <button class="auth-button" id="addSessionBtn"
                            style="background: var(--accent-color); width: auto;">
                            <i class="fas fa-plus"></i> Add Session
                        </button>
                    </div>

                    <div class="modern-calendar-nav">
                        <button class="nav-button prev" id="prevMonth"><i class="fas fa-chevron-left"></i></button>
                        <div class="month-display">
                            <h2 id="currentMonth" class="month-text">September 2025</h2>
                        </div>
                        <button class="nav-button next" id="nextMonth"><i class="fas fa-chevron-right"></i></button>
                    </div>

                    <div class="modern-calendar">
                        <div class="calendar-weekdays">
                            <div class="weekday">SUN</div>
                            <div class="weekday">MON</div>
                            <div class="weekday">TUE</div>
                            <div class="weekday">WED</div>
                            <div class="weekday">THU</div>
                            <div class="weekday">FRI</div>
                            <div class="weekday">SAT</div>
                        </div>
                        <div class="calendar-days" id="calendarBody"></div>
                    </div>

                    <div id="loadingIndicator" class="modern-loading" style="display: none;">
                        <div class="loading-spinner"></div>
                        <span>Loading schedule...</span>
                    </div>
                </div>
            </div>

            <!-- TAB 2: TRACKER -->
            <div id="main-content-tracker" class="main-tab-content" style="display: none;">

                <div style="display: grid; grid-template-columns: 1fr; gap: 2rem; margin-bottom: 2rem;">
                    <!-- General Settings Integration -->
                    <div
                        style="background: var(--bg-primary); padding: 1.5rem; border-radius: 12px; border: 1px solid var(--border-color);">
                        <h4
                            style="font-size: 1.1rem; font-weight: 600; margin-bottom: 1rem; color: var(--text-primary);">
                            Global
                            Hour Requirements</h4>

                        <div style="margin-bottom: 1rem; padding-top: 1rem; border-top: 1px solid var(--border-color);">
                            <h5
                                style="font-size: 1rem; font-weight: 600; margin-bottom: 1rem; color: var(--text-primary);">
                                Monthly Target Requirements
                            </h5>

                            <div id="monthlySettingsGrid"
                                style="display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 1rem;">
                                <!-- Month setting cards will be injected here by JS -->
                            </div>
                        </div>

                        <button class="auth-button" onclick="saveAllGeneralSettings()"
                            style="margin-top: 1.5rem; width: 100%;">
                            <i class="fas fa-save"></i> Save All Target Requirements
                        </button>
                    </div>

                    <!-- Member Management Integration -->
                    <div
                        style="background: var(--bg-primary); padding: 1.5rem; border-radius: 12px; border: 1px solid var(--border-color);">
                        <div
                            style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem;">
                            <h4 style="font-size: 1.1rem; font-weight: 600; color: var(--text-primary);">Student
                                Classification</h4>
                            <input type="text" id="memberSearch" placeholder="Search students..." class="auth-input"
                                style="width: 200px; padding: 0.5rem;">
                        </div>

                        <div
                            style="max-height: 250px; overflow-y: auto; border: 1px solid var(--border-color); border-radius: 8px;">
                            <table style="width: 100%; border-collapse: collapse; font-size: 0.85rem;">
                                <thead style="background: var(--bg-secondary); position: sticky; top: 0;">
                                    <tr>
                                        <th
                                            style="padding: 0.5rem; text-align: left; border-bottom: 1px solid var(--border-color);">
                                            Name</th>
                                        <th
                                            style="padding: 0.5rem; text-align: left; border-bottom: 1px solid var(--border-color);">
                                            Type</th>
                                        <th
                                            style="padding: 0.5rem; text-align: right; border-bottom: 1px solid var(--border-color);">
                                            Action</th>
                                    </tr>
                                </thead>
                                <tbody id="membersTableBody">
                                    <!-- Populated via JS -->
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>

                <!-- Hour Adjustments Integration -->
                <div
                    style="background: var(--bg-primary); padding: 1.5rem; border-radius: 12px; border: 1px solid var(--border-color); margin-bottom: 2rem;">
                    <h4 style="font-size: 1.1rem; font-weight: 600; margin-bottom: 1rem; color: var(--text-primary);">
                        Add/Remove
                        Hours Adjustment</h4>

                    <form id="hourAdjustmentForm" class="create-meeting-form-grid">
                        <div class="auth-input-group" style="margin-bottom: 0;">
                            <label class="auth-label">Target</label>
                            <select id="adjTarget" class="auth-input" onchange="toggleAdjUserSelect()">
                                <option value="all">All</option>
                                <option value="individual">Specific Student</option>
                            </select>
                        </div>
                        <div class="auth-input-group" id="adjUserSelectDiv" style="display: none; margin-bottom: 0;">
                            <label class="auth-label">Student</label>
                            <select id="adjUserId" class="auth-input"></select>
                        </div>
                        <div class="auth-input-group" style="margin-bottom: 0;">
                            <label class="auth-label">Amount</label>
                            <input type="number" id="adjAmount" class="auth-input" step="0.5" placeholder="+/-"
                                required>
                        </div>
                        <div class="auth-input-group" style="margin-bottom: 0;">
                            <label class="auth-label">Month</label>
                            <select id="adjMonth" class="auth-input" required>
                                <option value="09">Sept</option>
                                <option value="10">Oct</option>
                                <option value="11">Nov</option>
                                <option value="12">Dec</option>
                                <option value="01">Jan</option>
                                <option value="02">Feb</option>
                                <option value="03">Mar</option>
                                <option value="04">Apr</option>
                                <option value="05">May</option>
                                <option value="06">Jun</option>
                            </select>
                        </div>
                        <div class="auth-input-group" style="margin-bottom: 0;">
                            <label class="auth-label">Reason</label>
                            <input type="text" id="adjReason" class="auth-input" placeholder="e.g. Extra credit"
                                required>
                        </div>
                        <button type="submit" class="auth-button" style="padding: 0.75rem 1rem;">
                            <i class="fas fa-plus"></i> Add
                        </button>
                    </form>

                    <div
                        style="margin-top: 1.5rem; max-height: 150px; overflow-y: auto; border: 1px solid var(--border-color); border-radius: 8px;">
                        <table style="width: 100%; border-collapse: collapse; font-size: 0.85rem;">
                            <thead style="background: var(--bg-secondary); position: sticky; top: 0;">
                                <tr>
                                    <th style="padding: 0.5rem; text-align: left;">Date</th>
                                    <th style="padding: 0.5rem; text-align: left;">Target</th>
                                    <th style="padding: 0.5rem; text-align: left;">Month</th>
                                    <th style="padding: 0.5rem; text-align: right;">Amount</th>
                                    <th style="padding: 0.5rem; text-align: left;">Reason</th>
                                    <th style="padding: 0.5rem; text-align: right;">Action</th>
                                </tr>
                            </thead>
                            <tbody id="adjustmentsTableBody"></tbody>
                        </table>
                    </div>
                </div>

                <!-- Tracker Printout -->
                <div class="hours-tracker-container">
                    <div style="margin-bottom: 2rem; display: flex; justify-content: center; gap: 1rem;">
                        <button id="monthlyViewBtn" class="view-toggle-btn active"
                            onclick="switchTrackerView('monthly')">
                            <i class="fas fa-calendar-alt"></i> Monthly Printout
                        </button>
                        <button id="statsViewBtn" class="view-toggle-btn" onclick="switchTrackerView('statistics')">
                            <i class="fas fa-chart-line"></i> Key Statistics
                        </button>
                    </div>

                    <div class="hours-table-container">
                        <div id="loadingContainer" class="loading-container">
                            <div class="loading-spinner"></div>
                        </div>
                        <div id="tableContainer" style="display: none;">
                            <div class="table-scroll">
                                <table class="hours-table">
                                    <thead>
                                        <tr>
                                            <th rowspan="2" class="student-name-header">Student Name</th>
                                            <th colspan="2" class="month-super-header">September</th>
                                            <th colspan="2" class="month-super-header">October</th>
                                            <th colspan="2" class="month-super-header">November</th>
                                            <th colspan="2" class="month-super-header">December</th>
                                            <th colspan="2" class="month-super-header">January</th>
                                            <th colspan="2" class="month-super-header">February</th>
                                            <th colspan="2" class="month-super-header">March</th>
                                            <th colspan="2" class="month-super-header">April</th>
                                            <th colspan="2" class="month-super-header">May</th>
                                            <th colspan="2" class="month-super-header">June</th>
                                        </tr>
                                        <tr>
                                            <th class="sub-header hours-done-header">Done</th>
                                            <th class="sub-header required-hours-header">Req</th>
                                            <th class="sub-header hours-done-header">Done</th>
                                            <th class="sub-header required-hours-header">Req</th>
                                            <th class="sub-header hours-done-header">Done</th>
                                            <th class="sub-header required-hours-header">Req</th>
                                            <th class="sub-header hours-done-header">Done</th>
                                            <th class="sub-header required-hours-header">Req</th>
                                            <th class="sub-header hours-done-header">Done</th>
                                            <th class="sub-header required-hours-header">Req</th>
                                            <th class="sub-header hours-done-header">Done</th>
                                            <th class="sub-header required-hours-header">Req</th>
                                            <th class="sub-header hours-done-header">Done</th>
                                            <th class="sub-header required-hours-header">Req</th>
                                            <th class="sub-header hours-done-header">Done</th>
                                            <th class="sub-header required-hours-header">Req</th>
                                            <th class="sub-header hours-done-header">Done</th>
                                            <th class="sub-header required-hours-header">Req</th>
                                            <th class="sub-header hours-done-header">Done</th>
                                            <th class="sub-header required-hours-header">Req</th>
                                        </tr>
                                    </thead>
                                    <tbody id="hoursTableBody"></tbody>
                                </table>
                            </div>
                        </div>
                    </div>

                    <div id="statsTableContainer" style="display: none;">
                        <div class="hours-table-container">
                            <div id="statsLoadingContainer" class="loading-container" style="display: none;">
                                <div class="loading-spinner"></div>
                            </div>
                            <div id="statsContentContainer">
                                <div class="table-scroll">
                                    <table class="hours-table">
                                        <thead>
                                            <tr>
                                                <th class="student-name-header">Student Name</th>
                                                <th>Hours Tutored This Month</th>
                                                <th>Hours Signed Up This Month</th>
                                                <th>Hours Tutored This Year</th>
                                                <th>Hours to Make Up So Far</th>
                                            </tr>
                                        </thead>
                                        <tbody id="statsTableBody"></tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- TAB 3: MEETINGS -->
            <div id="main-content-meetings" class="main-tab-content" style="display: none;">
                <div
                    style="background: var(--bg-primary); padding: 2rem; border-radius: 12px; border: 1px solid var(--border-color);">
                    <div
                        style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem;">
                        <h4 style="font-size: 1.25rem; font-weight: 700; color: var(--text-primary);"><i
                                class="fas fa-users-class"></i> Create New Meeting</h4>
                    </div>

                    <form id="createMeetingForm" class="manual-adj-form-grid">
                        <div class="auth-input-group" style="margin-bottom: 0;">
                            <label class="auth-label">Title</label>
                            <input type="text" id="meetingTitle" class="auth-input"
                                placeholder="e.g. November General Meeting" required>
                        </div>
                        <div class="auth-input-group" style="margin-bottom: 0;">
                            <label class="auth-label">Code</label>
                            <div style="display: flex; gap: 0.5rem;">
                                <input type="text" id="meetingCode" class="auth-input" placeholder="CODE" required>
                                <button type="button" class="auth-button" style="padding: 0.5rem 1rem; width: auto;"
                                    onclick="generateMeetingCode()">
                                    <i class="fas fa-random"></i>
                                </button>
                            </div>
                        </div>
                        <div class="auth-input-group" style="margin-bottom: 0;">
                            <label class="auth-label">Value (Hours)</label>
                            <input type="number" id="meetingValue" class="auth-input" value="1.0" step="0.5" required>
                        </div>
                        <button type="submit" class="auth-button" style="padding: 0.75rem 1.5rem; margin-bottom: 2px;">
                            <i class="fas fa-plus-circle"></i> Create
                        </button>
                    </form>

                    <h4 style="font-size: 1.25rem; font-weight: 700; color: var(--text-primary); margin-bottom: 1rem;">
                        <i class="fas fa-history"></i> Recent Meetings
                    </h4>

                    <div id="meetingDetailsList">
                        <!-- Filled by JS -->
                    </div>
                </div>
            </div>

            <!-- TAB 4: LEADERBOARD -->
            <div id="main-content-leaderboard" class="main-tab-content" style="display: none;">
                <div class="grid-cols-2">

                    <!-- Top 5 Card -->
                    <div
                        style="background: var(--bg-primary); padding: 1.5rem; border-radius: 12px; border: 1px solid var(--border-color);">
                        <div
                            style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem;">
                            <h4 style="font-size: 1.1rem; font-weight: 600; color: #10b981;"><i
                                    class="fas fa-medal"></i> Top 5: Most Hours Tutored</h4>
                        </div>
                        <div
                            style="max-height: 250px; overflow-y: auto; border: 1px solid var(--border-color); border-radius: 8px;">
                            <table style="width: 100%; border-collapse: collapse; font-size: 0.85rem;">
                                <thead style="background: var(--bg-secondary); position: sticky; top: 0;">
                                    <tr>
                                        <th
                                            style="padding: 0.5rem; text-align: left; border-bottom: 1px solid var(--border-color);">
                                            Name</th>
                                        <th
                                            style="padding: 0.5rem; text-align: right; border-bottom: 1px solid var(--border-color);">
                                            Total Tutored</th>
                                    </tr>
                                </thead>
                                <tbody id="leaderboardTop5Body">
                                    <tr>
                                        <td colspan="2" style="text-align: center; padding: 1rem;">Loading...</td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>

                    <!-- Bottom 5 Card -->
                    <div
                        style="background: var(--bg-primary); padding: 1.5rem; border-radius: 12px; border: 1px solid var(--border-color);">
                        <div
                            style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem;">
                            <h4 style="font-size: 1.1rem; font-weight: 600; color: #ef4444;"><i
                                    class="fas fa-exclamation-triangle"></i> Bottom 5: Most Hours to Make Up</h4>
                        </div>
                        <div
                            style="max-height: 250px; overflow-y: auto; border: 1px solid var(--border-color); border-radius: 8px;">
                            <table style="width: 100%; border-collapse: collapse; font-size: 0.85rem;">
                                <thead style="background: var(--bg-secondary); position: sticky; top: 0;">
                                    <tr>
                                        <th
                                            style="padding: 0.5rem; text-align: left; border-bottom: 1px solid var(--border-color);">
                                            Name</th>
                                        <th
                                            style="padding: 0.5rem; text-align: right; border-bottom: 1px solid var(--border-color);">
                                            Deficit Owed</th>
                                    </tr>
                                </thead>
                                <tbody id="leaderboardBottom5Body">
                                    <tr>
                                        <td colspan="2" style="text-align: center; padding: 1rem;">Loading...</td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Session Modals (Kept from Original) -->
            <div id="sessionModal" class="modern-modal" style="display: none;">
                <div class="modal-backdrop"></div>
                <div class="modern-modal-content" style="max-width: 600px;">
                    <div class="modal-header-modern">
                        <div class="modal-title-section">
                            <i class="fas fa-edit modal-icon"></i>
                            <h3 id="modalTitle" class="modal-title-text">Manage Sessions</h3>
                        </div>
                        <button class="modern-close-btn" id="closeModal"><i class="fas fa-times"></i></button>
                    </div>
                    <div class="modal-body-modern" id="modalBody"></div>
                </div>
            </div>

            <div id="addSessionModal" class="modern-modal" style="display: none;">
                <div class="modal-backdrop"></div>
                <div class="modern-modal-content" style="max-width: 500px;">
                    <div class="modal-header-modern">
                        <div class="modal-title-section">
                            <i class="fas fa-plus modal-icon"></i>
                            <h3 class="modal-title-text">Add New Session</h3>
                        </div>
                        <button class="modern-close-btn" id="closeAddModal"><i class="fas fa-times"></i></button>
                    </div>
                    <div class="modal-body-modern">
                        <form id="addSessionForm" style="display: grid; gap: 1rem;">
                            <div class="auth-input-group">
                                <label for="sessionDate" class="auth-label">Date</label>
                                <input type="date" id="sessionDate" class="auth-input" required>
                            </div>
                            <div class="auth-input-group">
                                <label for="sessionDay" class="auth-label">Day of Week</label>
                                <select id="sessionDay" class="auth-input" required>
                                    <option value="">Select Day</option>
                                    <option value="Monday">Monday</option>
                                    <option value="Tuesday">Tuesday</option>
                                    <option value="Wednesday">Wednesday</option>
                                    <option value="Thursday">Thursday</option>
                                    <option value="Friday">Friday</option>
                                    <option value="Saturday">Saturday</option>
                                    <option value="Sunday">Sunday</option>
                                </select>
                            </div>
                            <div class="auth-input-group">
                                <label for="sessionTime" class="auth-label">Time</label>
                                <input type="text" id="sessionTime" class="auth-input"
                                    placeholder="e.g., 3:15 PM - 4:15 PM" required>
                            </div>
                            <div class="auth-input-group">
                                <label for="sessionRoom" class="auth-label">Room</label>
                                <input type="text" id="sessionRoom" class="auth-input" placeholder="e.g., Room 320"
                                    required>
                            </div>
                            <div class="auth-input-group">
                                <label for="sessionMaxTutors" class="auth-label">Max Tutors</label>
                                <input type="number" id="sessionMaxTutors" class="auth-input" min="1" max="20" value="6"
                                    required>
                            </div>
                            <button type="submit" class="auth-button" style="margin-top: 1rem;">
                                <i class="fas fa-plus"></i> Add Session
                            </button>
                        </form>
                    </div>
                </div>
            </div>

        </div>
    </main>

    <!-- JavaScript Unification -->
    <script>
        // Data stores
        let currentDate = new Date();
        let tutoringSessions = {};
        let allStudents = [];
        let globalSettings = {};
        let currentTrackerView = 'monthly';
        let statsData = null;

        // Navbar scroll effect
        window.addEventListener('scroll', function () {
            const navbar = document.getElementById('navbar');
            if (window.scrollY > 50) {
                navbar.classList.add('scrolled');
            } else {
                navbar.classList.remove('scrolled');
            }
        });

        // Initialize immediately
        document.addEventListener('DOMContentLoaded', async () => {
            await Promise.all([
                initializeCalendar(),
                loadSettings(),
                loadStudentsList(),
                loadStudentHours(),
            ]);
            // Settings uses students list, so load adjustments and meetings after basic loading
            loadAdjustments();
            loadMeetings();
        });

        // --- Tab Switching Logic ---
        function switchMainTab(tabName) {
            document.querySelectorAll('.main-tab-content').forEach(el => el.style.display = 'none');
            document.querySelectorAll('.main-tab-btn').forEach(el => {
                el.classList.remove('active');
            });

            document.getElementById(`main-content-${tabName}`).style.display = 'block';
            document.getElementById(`main-tab-${tabName}`).classList.add('active');

            // Trigger specific loads if needed
            if (tabName === 'tracker') {
                if (!statsData) loadStudentStatistics();
            } else if (tabName === 'leaderboard') {
                loadLeaderboard();
            }
        }

        function switchTrackerView(view) {
            currentTrackerView = view;
            const monthlyViewBtn = document.getElementById('monthlyViewBtn');
            const statsViewBtn = document.getElementById('statsViewBtn');
            const monthlyContainer = document.getElementById('tableContainer');
            const statsContainer = document.getElementById('statsTableContainer');

            if (view === 'monthly') {
                monthlyViewBtn.classList.add('active');
                statsViewBtn.classList.remove('active');
                monthlyContainer.style.display = 'block';
                statsContainer.style.display = 'none';
            } else {
                monthlyViewBtn.classList.remove('active');
                statsViewBtn.classList.add('active');
                monthlyContainer.style.display = 'none';
                statsContainer.style.display = 'block';

                if (!statsData) loadStudentStatistics();
            }
        }


        // --- Calendar Logic ---
        function parseDate(dateString) {
            const [year, month, day] = dateString.split('-').map(Number);
            return new Date(year, month - 1, day);
        }

        async function initializeCalendar() {
            updateCalendarDisplay();
            await loadTutoringData();
        }

        function updateCalendarDisplay() {
            const monthNames = ['January', 'February', 'March', 'April', 'May', 'June', 'July', 'August', 'September', 'October', 'November', 'December'];
            document.getElementById('currentMonth').textContent = `${monthNames[currentDate.getMonth()]} ${currentDate.getFullYear()}`;
            generateCalendarDays();
        }

        function generateCalendarDays() {
            const calendarBody = document.getElementById('calendarBody');
            calendarBody.innerHTML = '';
            const firstDay = new Date(currentDate.getFullYear(), currentDate.getMonth(), 1);
            const lastDay = new Date(currentDate.getFullYear(), currentDate.getMonth() + 1, 0);
            const daysInMonth = lastDay.getDate();
            const startingDayOfWeek = firstDay.getDay();

            for (let i = 0; i < startingDayOfWeek; i++) {
                const emptyDay = document.createElement('div');
                emptyDay.className = 'calendar-day empty';
                calendarBody.appendChild(emptyDay);
            }

            for (let day = 1; day <= daysInMonth; day++) {
                const dayElement = document.createElement('div');
                dayElement.className = 'calendar-day';

                const dateKey = formatDateKey(currentDate.getFullYear(), currentDate.getMonth(), day);
                const sessionsForDay = tutoringSessions[dateKey] || [];

                const today = new Date();
                if (day === today.getDate() && currentDate.getMonth() === today.getMonth() && currentDate.getFullYear() === today.getFullYear()) {
                    dayElement.classList.add('today');
                }

                let sessionsHtml = '';
                if (sessionsForDay.length > 0) {
                    sessionsHtml = '<div style="margin-top: 4px; display: flex; flex-direction: column; gap: 4px; overflow-y: auto; max-height: 80px;">';
                    sessionsForDay.forEach(s => {
                        const bg = s.cancelled ? '#fef2f2' : '#f0fdf4';
                        const color = s.cancelled ? '#dc2626' : '#16a34a';
                        const border = s.cancelled ? '#fecaca' : '#bbf7d0';
                        sessionsHtml += `<div style="background: ${bg}; color: ${color}; border: 1px solid ${border}; border-radius: 4px; padding: 4px; font-size: 0.75rem; line-height: 1.2; text-align: left;">`;
                        sessionsHtml += `<strong>${s.time}</strong><br>`;
                        if (s.signedUpUsers && s.signedUpUsers.length > 0) {
                            s.signedUpUsers.forEach(u => { sessionsHtml += `<span style="color: #4b5563; font-size: 0.7rem;">• ${u}</span><br>`; });
                        } else {
                            sessionsHtml += `<span style="color: #9ca3af; font-size: 0.7rem; font-style: italic;">No signups</span>`;
                        }
                        sessionsHtml += `</div>`;
                    });
                    sessionsHtml += '</div>';
                }

                dayElement.innerHTML = `
                    <div class="day-number">${day}</div>
                    ${sessionsHtml}
                `;

                if (sessionsForDay.length > 0) {
                    dayElement.classList.add('has-sessions');
                    dayElement.addEventListener('click', () => showSessionManagement(dateKey, sessionsForDay));
                } else {
                    dayElement.addEventListener('click', () => openAddSessionModal(dateKey));
                }

                calendarBody.appendChild(dayElement);
            }
        }

        function formatDateKey(year, month, day) {
            return `${year}-${String(month + 1).padStart(2, '0')}-${String(day).padStart(2, '0')}`;
        }

        function showSessionManagement(dateKey, sessions) {
            const modal = document.getElementById('sessionModal');
            const date = parseDate(dateKey);
            document.getElementById('modalTitle').textContent = `Manage Sessions - ${date.toLocaleDateString('en-US', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' })}`;

            const sessionCards = sessions.map(session => {
                const bgColor = session.cancelled ? '#fef2f2' : 'white';
                return `
                <div class="session-management-card" style="background: ${bgColor}; border: 1px solid #e5e7eb; border-radius: 12px; padding: 1.5rem; margin-bottom: 1rem;">
                    ${session.cancelled ? '<div style="background: #dc2626; color: white; padding: 0.5rem 1rem; border-radius: 6px; margin-bottom: 1rem; text-align: center; font-weight: 600;"><i class="fas fa-ban"></i> CANCELLED SESSION</div>' : ''}
                    <div class="session-edit-form">
                        <div style="display: grid; grid-template-columns: 1.5fr 1fr; gap: 1rem; margin-bottom: 1rem;">
                            <div class="auth-input-group"><label class="auth-label">Time</label><input type="text" class="auth-input session-time" value="${session.time}"></div>
                            <div class="auth-input-group"><label class="auth-label">Max Tutors</label><input type="number" class="session-number-input session-max-tutors" value="${session.maxTutors}" min="1" max="20"></div>
                        </div>
                        <div style="margin-bottom: 1.5rem;">
                            <div class="auth-input-group"><label class="auth-label">Room</label><input type="text" class="auth-input session-room" value="${session.room || 'TBD'}"></div>
                        </div>
                        <div style="margin-bottom: 1rem; padding: 1rem; background: #f8fafc; border-radius: 8px;">
                            <strong>Current Participants (${session.signedUp || 0}/${session.maxTutors}):</strong>
                            ${session.signedUpUsers && session.signedUpUsers.length > 0 ? session.signedUpUsers.map(user => `<span style="display: inline-block; background: white; padding: 0.25rem 0.5rem; margin: 0.25rem; border-radius: 4px; font-size: 0.875rem; border: 1px solid #e5e7eb;">${user}</span>`).join('') : '<p style="margin: 0.5rem 0 0 0; color: #64748b; font-style: italic;">No participants yet</p>'}
                        </div>
                        <div style="display: flex; gap: 1rem; justify-content: flex-end;">
                            ${session.cancelled ? `<button class="auth-button" style="background: #10b981;" onclick="reactivateSession('${dateKey}', '${session.time}')"><i class="fas fa-check"></i> Reactivate</button>` : `<button class="auth-button" style="background: #ef4444;" onclick="cancelSession('${dateKey}', '${session.time}')"><i class="fas fa-ban"></i> Cancel Session</button>`}
                            <button class="auth-button" onclick="updateSession('${dateKey}', '${session.time}', this.closest('.session-edit-form'))"><i class="fas fa-save"></i> Save Changes</button>
                        </div>
                    </div>
                </div>`;
            }).join('');

            document.getElementById('modalBody').innerHTML = sessionCards + `<div style="margin-top: 1.5rem; padding-top: 1.5rem; border-top: 1px solid #e5e7eb;"><button class="auth-button" style="background: #10b981;" onclick="openAddSessionModal('${dateKey}')"><i class="fas fa-plus"></i> Add Another Session</button></div>`;
            modal.style.display = 'flex';
        }

        async function loadTutoringData() {
            document.getElementById('loadingIndicator').style.display = 'block';
            try {
                const response = await fetch('/api/tutoring-schedule');
                const data = await response.json();
                tutoringSessions = {};
                data.forEach(session => {
                    const dateKey = session.date;
                    if (!tutoringSessions[dateKey]) { tutoringSessions[dateKey] = []; }
                    tutoringSessions[dateKey].push({
                        time: session.time, maxTutors: parseInt(session.maxTutors),
                        cancelled: session.cancelled === true || session.cancelled === 'Yes',
                        signedUp: session.signedUp || 0, signedUpUsers: session.signedUpUsers || [], room: session.room || 'TBD'
                    });
                });
                generateCalendarDays();
            } catch (error) {
                console.error(error);
            } finally {
                document.getElementById('loadingIndicator').style.display = 'none';
            }
        }

        function openAddSessionModal(dateKey = null) {
            const modal = document.getElementById('addSessionModal');
            if (dateKey) {
                document.getElementById('sessionDate').value = dateKey;
                document.getElementById('sessionDay').value = ['Sunday', 'Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday'][new Date(dateKey).getDay()];
            } else {
                const today = new Date();
                document.getElementById('sessionDate').value = today.toISOString().split('T')[0];
                document.getElementById('sessionDay').value = ['Sunday', 'Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday'][today.getDay()];
            }
            modal.style.display = 'flex';
        }

        async function updateSession(dateKey, originalTime, formElement) {
            const newTime = formElement.querySelector('.session-time').value;
            const maxTutors = parseInt(formElement.querySelector('.session-max-tutors').value);
            const room = formElement.querySelector('.session-room').value;
            try {
                const response = await fetch('/api/update-session', {
                    method: 'POST', headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ date: dateKey, time: originalTime, updates: { time: newTime, maxTutors, room }, applyToFuture: false })
                });
                const result = await response.json();
                if (result.success) {
                    alert('Session updated successfully!');
                    await loadTutoringData();
                    document.getElementById('sessionModal').style.display = 'none';
                }
            } catch (error) { console.error(error); }
        }

        async function cancelSession(dateKey, time) {
            if (!confirm('Cancel this session? students will be notified.')) return;
            try {
                const response = await fetch('/api/update-session', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ date: dateKey, time, updates: { cancelled: true } }) });
                if ((await response.json()).success) { await loadTutoringData(); document.getElementById('sessionModal').style.display = 'none'; }
            } catch (error) { console.error(error); }
        }

        async function reactivateSession(dateKey, time) {
            if (!confirm('Reactivate this session?')) return;
            try {
                const response = await fetch('/api/update-session', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ date: dateKey, time, updates: { cancelled: false } }) });
                if ((await response.json()).success) { await loadTutoringData(); document.getElementById('sessionModal').style.display = 'none'; }
            } catch (error) { console.error(error); }
        }

        // --- Modals Listeners ---
        document.getElementById('prevMonth').addEventListener('click', () => { currentDate.setMonth(currentDate.getMonth() - 1); initializeCalendar(); });
        document.getElementById('nextMonth').addEventListener('click', () => { currentDate.setMonth(currentDate.getMonth() + 1); initializeCalendar(); });
        document.getElementById('closeModal').addEventListener('click', () => document.getElementById('sessionModal').style.display = 'none');
        document.getElementById('closeAddModal').addEventListener('click', () => document.getElementById('addSessionModal').style.display = 'none');
        document.getElementById('sessionModal').addEventListener('click', (e) => { if (e.target.id === 'sessionModal' || e.target.classList.contains('modal-backdrop')) document.getElementById('sessionModal').style.display = 'none'; });
        document.getElementById('addSessionModal').addEventListener('click', (e) => { if (e.target.id === 'addSessionModal' || e.target.classList.contains('modal-backdrop')) document.getElementById('addSessionModal').style.display = 'none'; });
        document.getElementById('addSessionBtn').addEventListener('click', () => openAddSessionModal());

        document.getElementById('addSessionForm').addEventListener('submit', async (e) => {
            e.preventDefault();
            try {
                const response = await fetch('/api/add-session', {
                    method: 'POST', headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        date: document.getElementById('sessionDate').value,
                        day: document.getElementById('sessionDay').value,
                        time: document.getElementById('sessionTime').value,
                        room: document.getElementById('sessionRoom').value,
                        maxTutors: parseInt(document.getElementById('sessionMaxTutors').value)
                    })
                });
                if ((await response.json()).success) {
                    alert('Session added!');
                    await loadTutoringData();
                    document.getElementById('addSessionModal').style.display = 'none';
                    document.getElementById('addSessionForm').reset();
                }
            } catch (error) { console.error(error); }
        });
        document.getElementById('sessionDate').addEventListener('change', (e) => { document.getElementById('sessionDay').value = ['Sunday', 'Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday'][new Date(e.target.value).getDay()]; });

        // --- Tracker Table Logic ---
        async function loadStudentHours() {
            try {
                const response = await fetch('/api/student-hours');
                const data = await response.json();
                const tbody = document.getElementById('hoursTableBody');

                let allRowsHtml = '';
                data.students.forEach(student => {
                    let rowHtml = '<tr>';
                    rowHtml += `<td>${student.firstName} ${student.lastName}</td>`;

                    const months = ['09', '10', '11', '12', '01', '02', '03', '04', '05', '06'];
                    months.forEach(month => {
                        const hours = student.monthlyHours[month] || 0;
                        const req = student.monthlyRequirements ? student.monthlyRequirements[month] : (month === '09' ? 2 : 2.5);
                        rowHtml += `<td><div class="hours-done-cell ${hours < req ? 'hours-done-low' : 'hours-done-good'}">${hours}</div></td>`;
                        rowHtml += `<td><div class="required-hours-cell">${req}</div></td>`;
                    });

                    rowHtml += '</tr>';
                    allRowsHtml += rowHtml;
                });

                tbody.innerHTML = allRowsHtml;
                document.getElementById('loadingContainer').style.display = 'none';
                document.getElementById('tableContainer').style.display = 'block';
            } catch (error) { console.error(error); }
        }

        async function loadStudentStatistics() {
            document.getElementById('statsLoadingContainer').style.display = 'flex';
            document.getElementById('statsContentContainer').style.display = 'none';
            try {
                const response = await fetch('/api/all-students-stats');
                statsData = (await response.json()).students;
                statsData.sort((a, b) => (`${a.lastName} ${a.firstName}`).localeCompare(`${b.lastName} ${b.firstName}`));
                const tbody = document.getElementById('statsTableBody');
                tbody.innerHTML = '';
                statsData.forEach(student => {
                    tbody.innerHTML += `<tr>
                        <td style="background:#f8fafc;position:sticky;left:0;z-index:9;border-right:2px solid #e5e7eb;font-weight:600;">${student.firstName} ${student.lastName}</td>
                        <td><div class="stats-cell">${student.hoursTutoredThisMonth}</div></td>
                        <td><div class="stats-cell">${student.hoursSignedUpThisMonth}</div></td>
                        <td><div class="stats-cell">${student.hoursTutoredThisYear}</div></td>
                        <td><div class="stats-cell ${student.hoursToMakeUpSoFar > 0 ? 'stats-behind' : 'stats-good'}">${student.hoursToMakeUpSoFar}</div></td>
                    </tr>`;
                });
                document.getElementById('statsLoadingContainer').style.display = 'none';
                document.getElementById('statsContentContainer').style.display = 'block';
            } catch (error) { console.error(error); }
        }

        // --- Global Settings Logic ---
        async function loadSettings() {
            try {
                const response = await fetch('/api/settings');
                globalSettings = await response.json();

                // Initialize default month object if coming from old database 
                // Settings.js migration should have handled this, but be safe on frontend too
                if (!globalSettings.memberRequirements['09']) {
                    const oldReq = globalSettings.memberRequirements;
                    globalSettings.memberRequirements = {};
                    const months = ['09', '10', '11', '12', '01', '02', '03', '04', '05', '06'];
                    months.forEach(m => {
                        globalSettings.memberRequirements[m] = {
                            New: oldReq.New || { baseHours: 2.5, penaltyRate: 0.5 },
                            Old: oldReq.Old || { baseHours: 1.0, penaltyRate: 0.5 },
                            Officer: oldReq.Officer || { baseHours: 0, penaltyRate: 0 }
                        };
                    });
                }

                renderMonthlySettingsGrid();
            } catch (error) { console.error(error); }
        }

        function renderMonthlySettingsGrid() {
            const container = document.getElementById('monthlySettingsGrid');
            const monthOrder = ['09', '10', '11', '12', '01', '02', '03', '04', '05', '06'];
            const monthNames = { '09': 'September', '10': 'October', '11': 'November', '12': 'December', '01': 'January', '02': 'February', '03': 'March', '04': 'April', '05': 'May', '06': 'June' };
            const penaltyStartIndex = monthOrder.indexOf(globalSettings.penaltyMonth);

            container.innerHTML = monthOrder.map((month, index) => {
                const reqs = globalSettings.memberRequirements[month] || {
                    New: { baseHours: 2.5, penaltyRate: 0.5 },
                    Old: { baseHours: 1.0, penaltyRate: 0.5 },
                    FreshMentors: { baseHours: 1.0, penaltyRate: 0.5 }
                };
                // Fallback for missing FreshMentors in existing records
                if (!reqs.FreshMentors) reqs.FreshMentors = { baseHours: 1.0, penaltyRate: 0.5 };

                const isPenaltyActive = penaltyStartIndex !== -1 && index >= penaltyStartIndex;

                return `
                    <div class="month-setting-card" data-month="${month}" style="background: var(--bg-secondary); border: 1px solid ${isPenaltyActive ? '#fca5a5' : 'var(--border-color)'}; border-radius: 8px; padding: 1rem; position: relative; overflow: hidden; box-shadow: 0 1px 2px rgba(0,0,0,0.05);">
                        ${isPenaltyActive ? '<div style="position: absolute; top: 0; left: 0; right: 0; height: 3px; background: #ef4444;"></div>' : ''}
                        
                        <div style="display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid var(--border-color); padding-bottom: 0.5rem; margin-bottom: 0.75rem;">
                            <h4 style="margin: 0; color: var(--text-primary); font-size: 1.05rem;">
                                ${isPenaltyActive ? '<i class="fas fa-exclamation-triangle" style="color: #ef4444; font-size: 0.85rem; margin-right: 4px;"></i>' : ''}
                                ${monthNames[month]}
                            </h4>
                        </div>
                        
                        <div style="display: grid; grid-template-columns: 1fr; gap: 0.75rem;">
                            <!-- New Members Section -->
                            <div style="background: var(--bg-primary); padding: 0.5rem; border-radius: 4px; border: 1px solid var(--border-color);">
                                <div style="font-size: 0.75rem; font-weight: 600; color: var(--text-secondary); margin-bottom: 0.25rem;">NEW MEMBERS</div>
                                <div style="display: flex; gap: 0.5rem;">
                                    <div style="flex: 1;">
                                        <label style="font-size: 0.7rem; color: var(--text-secondary); display: block;">Base</label>
                                        <input type="number" class="auth-input req-new-base" value="${reqs.New.baseHours}" step="0.5" style="padding: 0.25rem; font-size: 0.9rem; width: 100%;">
                                    </div>
                                    <div style="flex: 1;">
                                        <label style="font-size: 0.7rem; color: var(--text-secondary); display: block;">Penalty</label>
                                        <input type="number" class="auth-input req-new-penalty" value="${reqs.New.penaltyRate}" step="0.1" style="padding: 0.25rem; font-size: 0.9rem; width: 100%;">
                                    </div>
                                </div>
                            </div>
                            
                            <!-- Old Members Section -->
                            <div style="background: var(--bg-primary); padding: 0.5rem; border-radius: 4px; border: 1px solid var(--border-color);">
                                <div style="font-size: 0.75rem; font-weight: 600; color: var(--text-secondary); margin-bottom: 0.25rem;">OLD MEMBERS</div>
                                <div style="display: flex; gap: 0.5rem;">
                                    <div style="flex: 1;">
                                        <label style="font-size: 0.7rem; color: var(--text-secondary); display: block;">Base</label>
                                        <input type="number" class="auth-input req-old-base" value="${reqs.Old.baseHours}" step="0.5" style="padding: 0.25rem; font-size: 0.9rem; width: 100%;">
                                    </div>
                                    <div style="flex: 1;">
                                        <label style="font-size: 0.7rem; color: var(--text-secondary); display: block;">Penalty</label>
                                        <input type="number" class="auth-input req-old-penalty" value="${reqs.Old.penaltyRate}" step="0.1" style="padding: 0.25rem; font-size: 0.9rem; width: 100%;">
                                    </div>
                                </div>
                            </div>

                            <!-- FreshMentors Section -->
                            <div style="background: var(--bg-primary); padding: 0.5rem; border-radius: 4px; border: 1px solid var(--border-color);">
                                <div style="font-size: 0.75rem; font-weight: 600; color: var(--text-secondary); margin-bottom: 0.25rem;">FRESHMENTORS</div>
                                <div style="display: flex; gap: 0.5rem;">
                                    <div style="flex: 1;">
                                        <label style="font-size: 0.7rem; color: var(--text-secondary); display: block;">Base</label>
                                        <input type="number" class="auth-input req-fresh-base" value="${reqs.FreshMentors.baseHours}" step="0.5" style="padding: 0.25rem; font-size: 0.9rem; width: 100%;">
                                    </div>
                                    <div style="flex: 1;">
                                        <label style="font-size: 0.7rem; color: var(--text-secondary); display: block;">Penalty</label>
                                        <input type="number" class="auth-input req-fresh-penalty" value="${reqs.FreshMentors.penaltyRate}" step="0.1" style="padding: 0.25rem; font-size: 0.9rem; width: 100%;">
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                `;
            }).join('');
        }

        async function saveAllGeneralSettings() {
            const cards = document.querySelectorAll('.month-setting-card');

            cards.forEach(card => {
                const month = card.getAttribute('data-month');
                const newBase = parseFloat(card.querySelector('.req-new-base').value) || 0;
                const newPenalty = parseFloat(card.querySelector('.req-new-penalty').value) || 0;
                const oldBase = parseFloat(card.querySelector('.req-old-base').value) || 0;
                const oldPenalty = parseFloat(card.querySelector('.req-old-penalty').value) || 0;
                const freshBase = parseFloat(card.querySelector('.req-fresh-base').value) || 0;
                const freshPenalty = parseFloat(card.querySelector('.req-fresh-penalty').value) || 0;

                globalSettings.memberRequirements[month] = {
                    New: { baseHours: newBase, penaltyRate: newPenalty },
                    Old: { baseHours: oldBase, penaltyRate: oldPenalty },
                    FreshMentors: { baseHours: freshBase, penaltyRate: freshPenalty },
                    Officer: globalSettings.memberRequirements[month]?.Officer || { baseHours: 0, penaltyRate: 0 }
                };
            });

            const updates = {
                penaltyMonth: globalSettings.penaltyMonth,
                memberRequirements: globalSettings.memberRequirements // Send the massive compiled object
            };

            try {
                const response = await fetch('/api/settings', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(updates) });
                if ((await response.json()).success) {
                    alert('All Target Requirements saved successfully!');
                    await loadStudentHours();
                }
            } catch (error) { console.error(error); }
        }

        // --- Member Management ---
        async function loadStudentsList() {
            try {
                const response = await fetch('/api/students-list');
                allStudents = await response.json();
                renderMembersTable(allStudents);
                document.getElementById('adjUserId').innerHTML = allStudents.map(s => `<option value="${s._id}">${s.firstName} ${s.lastName}</option>`).join('');
            } catch (error) { console.error(error); }
        }

        function renderMembersTable(students) {
            document.getElementById('membersTableBody').innerHTML = students.map(s => {
                const mt = s.memberType || 'New';
                let bgStyle, copyStyle;
                if (mt === 'Old') {
                    bgStyle = 'background: #dbeafe; color: #1e40af;';
                } else if (mt === 'FreshMentors') {
                    bgStyle = 'background: #ede9fe; color: #4c1d95;';
                } else {
                    bgStyle = 'background: #d1fae5; color: #065f46;'; // New
                }

                const cycleMap = { 'New': 'Old', 'Old': 'FreshMentors', 'FreshMentors': 'New' };
                const nextType = cycleMap[mt] || 'New';

                return `
                <tr style="border-bottom: 1px solid #f3f4f6;">
                    <td style="padding: 0.5rem; white-space:nowrap">${s.firstName} ${s.lastName} <br><span style="font-size:0.75rem; color:#6b7280">${s.email}</span></td>
                    <td style="padding: 0.5rem;"><span style="padding: 0.25rem 0.5rem; border-radius: 9999px; font-size: 0.75rem; font-weight: 500; ${bgStyle}">${mt}</span></td>
                    <td style="padding: 0.5rem; text-align: right;"><button onclick="toggleMemberType('${s._id}', '${mt}')" style="padding: 0.25rem 0.5rem; border: 1px solid #e5e7eb; background: white; border-radius: 4px; cursor: pointer; font-size: 0.75rem;">Switch to ${nextType}</button></td>
                </tr>
                `;
            }).join('');
        }

        document.getElementById('memberSearch').addEventListener('input', (e) => {
            const term = e.target.value.toLowerCase();
            renderMembersTable(allStudents.filter(s => s.firstName.toLowerCase().includes(term) || s.lastName.toLowerCase().includes(term) || s.email.toLowerCase().includes(term)));
        });

        async function toggleMemberType(userId, currentType) {
            const cycleMap = { 'New': 'Old', 'Old': 'FreshMentors', 'FreshMentors': 'New' };
            const nextType = cycleMap[currentType || 'New'] || 'New';
            try {
                const response = await fetch('/api/members/update-type', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ updates: [{ userId, memberType: nextType }] }) });
                if ((await response.json()).success) { loadStudentsList(); await loadStudentHours(); }
            } catch (error) { console.error(error); }
        }

        // --- Adjustments Logic ---
        function toggleAdjUserSelect() { document.getElementById('adjUserSelectDiv').style.display = document.getElementById('adjTarget').value === 'individual' ? 'block' : 'none'; }

        document.getElementById('hourAdjustmentForm').addEventListener('submit', async (e) => {
            e.preventDefault();
            const target = document.getElementById('adjTarget').value;
            const body = {
                userId: target === 'individual' ? document.getElementById('adjUserId').value : null,
                amount: parseFloat(document.getElementById('adjAmount').value),
                monthApplied: document.getElementById('adjMonth').value,
                reason: document.getElementById('adjReason').value
            };
            try {
                const response = await fetch('/api/hours/adjust', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(body) });
                if ((await response.json()).success) { alert('Adjustment created!'); document.getElementById('hourAdjustmentForm').reset(); loadAdjustments(); await loadStudentHours(); }
            } catch (error) { console.error(error); }
        });

        async function loadAdjustments() {
            try {
                const response = await fetch('/api/hours/adjustments');
                document.getElementById('adjustmentsTableBody').innerHTML = (await response.json()).map(adj => `
                    <tr style="border-bottom: 1px solid #e5e7eb;">
                        <td style="padding: 0.5rem;">${new Date(adj.createdAt).toLocaleDateString()}</td>
                        <td style="padding: 0.5rem; font-weight: 500;">${adj.userId ? `${adj.userId.firstName} ${adj.userId.lastName}` : '<span style="color: #6b7280;">All Students</span>'}</td>
                        <td style="padding: 0.5rem;">${adj.monthApplied}</td>
                        <td style="padding: 0.5rem; text-align: right; color: ${adj.amount >= 0 ? 'green' : 'red'};">${adj.amount > 0 ? '+' : ''}${adj.amount}</td>
                        <td style="padding: 0.5rem;">${adj.reason}</td>
                        <td style="padding: 0.5rem; text-align: right;"><button onclick="deleteAdjustment('${adj._id}')" style="color: #ef4444; background: none; border: none; cursor: pointer;"><i class="fas fa-trash"></i></button></td>
                    </tr>
                `).join('');
            } catch (error) { console.error(error); }
        }

        async function deleteAdjustment(id) {
            if (!confirm('Delete this adjustment?')) return;
            await fetch(`/api/hours/adjustments/${id}`, { method: 'DELETE' });
            loadAdjustments();
            await loadStudentHours();
        }

        // --- Meetings Logic ---
        function generateMeetingCode() { document.getElementById('meetingCode').value = Array.from({ length: 6 }, () => 'ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789'.charAt(Math.floor(Math.random() * 36))).join(''); }

        document.getElementById('createMeetingForm').addEventListener('submit', async function (e) {
            e.preventDefault();
            try {
                const response = await fetch('/api/meetings', {
                    method: 'POST', headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ title: document.getElementById('meetingTitle').value, code: document.getElementById('meetingCode').value, value: parseFloat(document.getElementById('meetingValue').value) })
                });
                if ((await response.json()).success) { alert('Meeting created!'); this.reset(); loadMeetings(); }
            } catch (error) { console.error(error); }
        });

        async function loadMeetings() {
            try {
                const response = await fetch('/api/meetings');
                const meetings = await response.json();

                // Construct the advanced display incorporating attendee details mapped from allStudents
                const container = document.getElementById('meetingDetailsList');
                container.innerHTML = meetings.map(m => {
                    // Create an explicit logic loop to split attendees and missed
                    const attendedIds = m.attendees.map(a => a._id ? a._id.toString() : a.toString());
                    const attendedStuds = allStudents.filter(s => attendedIds.includes(s._id.toString()));
                    const missedStuds = allStudents.filter(s => !attendedIds.includes(s._id.toString()));

                    return `
                    <div style="border: 1px solid #e5e7eb; border-radius: 8px; padding: 1.5rem; margin-bottom: 1.5rem; background: #fafafa;">
                        <div style="display: flex; justify-content: space-between; align-items: start; margin-bottom: 1rem;">
                            <div>
                                <h5 style="font-size: 1.1rem; font-weight: 700; color: #1f2937; margin-bottom: 0.25rem;">${m.title}</h5>
                                <div style="color: #6b7280; font-size: 0.9rem;">
                                    <i class="fas fa-calendar-day"></i> ${new Date(m.date).toLocaleDateString()} &nbsp; | &nbsp; 
                                    <i class="fas fa-clock"></i> ${m.value} Hours &nbsp; | &nbsp; 
                                    <span style="font-family: monospace; background: #e5e7eb; padding: 0.1rem 0.4rem; border-radius: 4px; color: #374151; font-weight: bold;">Code: ${m.code}</span>
                                </div>
                            </div>
                            <div style="text-align: right;">
                                <span style="display: inline-block; padding: 0.25rem 0.75rem; border-radius: 9999px; font-size: 0.8rem; font-weight: 600; margin-bottom: 0.5rem; ${m.isActive ? 'background: #ecfdf5; color: #059669; border: 1px solid #a7f3d0;' : 'background: #f3f4f6; color: #4b5563; border: 1px solid #d1d5db;'}">${m.isActive ? 'ACTIVE' : 'CLOSED'}</span>
                                <br>
                                <button onclick="toggleMeeting('${m._id}')" style="background: ${m.isActive ? '#ef4444' : '#3b82f6'}; color: white; border: none; padding: 0.4rem 0.8rem; border-radius: 6px; font-size: 0.8rem; font-weight: 600; cursor: pointer;">
                                    ${m.isActive ? 'Close Meeting' : 'Reopen Meeting'}
                                </button>
                            </div>
                        </div>

                        <div class="meeting-attendees-box">
                            <div class="attended-list">
                                <h5><i class="fas fa-check-circle"></i> Attended (${attendedStuds.length})</h5>
                                ${attendedStuds.length === 0 ? '<em style="color:#9ca3af; font-size: 0.85rem;">No one has checked in yet</em>' : ''}
                                ${attendedStuds.map(s => `<div class="student-item">• ${s.firstName} ${s.lastName}</div>`).join('')}
                            </div>
                            <div class="missed-list">
                                <h5><i class="fas fa-times-circle"></i> Did Not Attend (${missedStuds.length})</h5>
                                ${missedStuds.map(s => `<div class="student-item">• ${s.firstName} ${s.lastName}</div>`).join('')}
                            </div>
                        </div>
                    </div>
                    `;
                }).join('');

            } catch (error) { console.error(error); }
        }

        async function toggleMeeting(id) {
            try {
                const response = await fetch(`/api/meetings/${id}/toggle`, { method: 'PATCH' });
                if ((await response.json()).success) loadMeetings();
            } catch (error) { console.error(error); }
        }

    </script>

    <!-- Theme Toggle -->
    <button class="theme-toggle-btn" id="themeToggleBtn" aria-label="Toggle Dark Mode">
        <i class="fas fa-moon"></i>
    </button>

    <script>
        // Theme toggling
        const themeBtn = document.getElementById('themeToggleBtn');
        if (themeBtn) {
            if (localStorage.getItem('theme') === 'dark') {
                themeBtn.innerHTML = '<i class="fas fa-sun"></i>';
            }
            themeBtn.addEventListener('click', () => {
                const isDark = document.documentElement.hasAttribute('data-theme');
                if (isDark) {
                    document.documentElement.removeAttribute('data-theme');
                    localStorage.setItem('theme', 'light');
                    themeBtn.innerHTML = '<i class="fas fa-moon"></i>';
                } else {
                    document.documentElement.setAttribute('data-theme', 'dark');
                    localStorage.setItem('theme', 'dark');
                    themeBtn.innerHTML = '<i class="fas fa-sun"></i>';
                }
            });
        }
        // Leaderboard logic
        async function loadLeaderboard() {
            try {
                const response = await fetch('/api/leaderboard');
                const data = await response.json();

                const top5Body = document.getElementById('leaderboardTop5Body');
                const bottom5Body = document.getElementById('leaderboardBottom5Body');

                if (data.top5 && data.top5.length > 0) {
                    top5Body.innerHTML = data.top5.map(student => `
                        <tr>
                            <td style="padding: 0.5rem; border-bottom: 1px solid #f1f5f9;">${student.name}</td>
                            <td style="padding: 0.5rem; border-bottom: 1px solid #f1f5f9; text-align: right; font-weight: 600; color: #10b981;">
                                ${student.hoursTutoredThisYear}
                            </td>
                        </tr>
                    `).join('');
                } else {
                    top5Body.innerHTML = `<tr><td colspan="2" style="text-align: center; padding: 1rem;">No data available</td></tr>`;
                }

                if (data.bottom5 && data.bottom5.length > 0) {
                    bottom5Body.innerHTML = data.bottom5.map(student => `
                        <tr>
                            <td style="padding: 0.5rem; border-bottom: 1px solid #f1f5f9;">${student.name}</td>
                            <td style="padding: 0.5rem; border-bottom: 1px solid #f1f5f9; text-align: right; font-weight: 600; color: #ef4444;">
                                ${student.hoursToMakeUp}
                            </td>
                        </tr>
                    `).join('');
                } else {
                    bottom5Body.innerHTML = `<tr><td colspan="2" style="text-align: center; padding: 1rem;">No data available</td></tr>`;
                }
            } catch (error) {
                console.error('Error loading leaderboard:', error);
                document.getElementById('leaderboardTop5Body').innerHTML = `<tr><td colspan="2" style="text-align: center; color: red;">Error loading data</td></tr>`;
                document.getElementById('leaderboardBottom5Body').innerHTML = `<tr><td colspan="2" style="text-align: center; color: red;">Error loading data</td></tr>`;
            }
        }

    </script>
</body>

</html>